{
  "name": "@userland-run/terminal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Console — the terminal front-end for userland.run / NanoVM",
  "scripts": {
    "sync-sw": "cp ../sdk/static/nano-sw.js public/nano-sw.js",
